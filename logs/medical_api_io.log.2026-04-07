INFO 2026-04-07 05:04:26,621 medical.api_io [request_id=10A77659-6852-4CEA-BB23-5934C0B469CE] HTTP 响应摘要: GET /api/v1/medical/members/13/summary/ status=200 duration_ms=27 bytes=48198 headers={"Content-Type": "application/json", "ETag": "\"7790481f8bcea280da49293bf7cf2be6\"", "Cache-Control": "private, max-age=120", "Vary": "Accept", "Allow": "GET, HEAD, OPTIONS"} body={"code": 0, "msg": "success", "data": {"member": {"id": 13, "name": "发发发", "gender": "male", "relationship": "self", "birth_date": "1993-04-05", "blood_type": "", "allergies": [], "chronic_conditions": [], "notes": "", "avatar_url": "", "is_primary": false, "created_at": "2026-04-05T02:20:48.072504Z", "updated_at": "2026-04-06T13:37:28.582288Z"}, "medical_cases": [{"id": 1, "member": 13, "record_type": "ai_upload", "status": 2, "title": "AI Medical Upload", "hospital_name": "", "age_at_visit": null, "diagnosis_summary": "{\"title\":\"东部战区总医院处方笺\",\"summary\":\"患者王玉兰，女，56岁，自费，神经内科门诊患者，2025年6月27日于东部战区总医院开具此处方，取药药房为第二药房，临床初步诊断为高血压、高脂血症、腔隙性脑梗死、失眠，处方包含三种药品，药费共计55.52元，处方30天内有效，无标注需皮试的药品。\",\"diagnosis\":\"高血压、高脂血症、腔隙性脑梗死、失眠\",\"occurredAt\":\"2025-06-27\",\"rawType\":\"处方笺\",\"items\":[{\"name\":\"阿托伐他汀钙片\",\"specification\":\"20mg×4盒\",\"type\":\"市公乙（4+...", "extra": {"resolved_mode": "general", "requested_mode": "", "source_file_count": "1"}, "created_at": "2026-04-06T10:56:48.671156Z", "updated_at": "2026-04-06T13:37:28.583648Z"}], "health_exam_reports": [{"id": 3, "member": 13, "institution_name": "苏州美健奥亚健康体检中心", "report_no": "", "exam_date": "2026-04-07", "exam_type": 1, "summary": null, "source": 2, "raw_ocr": {"text": "=== File 1: 体检报告_1.pdf ===\n苏州美健奥亚健康体检中心\n赵道凯 先生\n单位名\n上海爱元通科技有限公司\n称：\n身份证： 34118119981029501X\n年龄： 25\n体检号： 2138111466\n体检时\n2023/1/8 7:59:12\n间：\n报告阅读说明\n报告阅读说明:\n1 您好，欢迎您选择美年大健康集团体检！我们为您提供健康管理、健康体检、临床检验、特色诊疗、中医养生\n等全方位的医疗健康服务。\n2 医学科技发展至今，现有的医疗技术手段，对于疾病的筛查仍具有局限性和时效性，本次体检由于所选项目受\n限，会无法发现某些潜在疾病；体检后未发现异常的项目，并不说明就没有潜在疾病，如果有疾病症状出现，请\n立即就医。\n3 本报告书仅对受检者本次所检结果负责;警示部位请您关注，示意图仅供参考。特别说明：对于结论为详见纸质\n报告的检测项目异常信息及国家规定的单独出报告的检测项目异常信息不纳入健康警示灯及主要阳性结果及建议\n中。\n主要阳性结果及异常情况\n主要阳性结果及异常情况(报告医师\n报告医师: 黄家忻\n黄家忻 审核医师\n审核医师: 何秋兰\n何秋兰)\n★ 心电图检查结果:\n窦性心动过缓(54次/分)\n★ 甲状腺彩超:\n甲状腺双叶囊肿（多发）\n异常指标解读\n异常指标解读\n窦性心动过缓\n窦性心动过缓\nB201600279\n【医学解释】\n【医学解释】\n成人窦性心律的频率低于60次/分，称为窦性心动过缓。\n【常见原因及后果】\n【常见原因及后果】\n常见于健康的青年人、运动员与睡眠状态。其他原因包括颅内疾患、严重缺氧、低温、甲状腺机能减退、阻\n塞性黄疸以及应用洋地黄等药物。亦可见于窦房结病变和急性下壁心肌梗死。 如心室率过于缓慢低于40次/分\n，可出现头晕、晕厥、心绞痛等。\n【建议】\n【建议】\n无症状的窦性心动过缓通常无需治疗。但如心率显著减慢，出现心排血量不足症状，可用药物治疗，严重者\n考虑心脏起搏器治疗。正规医院专科诊治。\n甲状腺囊肿（多发）\n甲状腺囊肿（多发）\n【医学解释】\n【医学解释】\n较小的囊肿可无症状，囊肿逐渐增大可出现压迫症状\n【常见原因及后果】\n【常见原因及后果】\n较小的囊肿可无症状，囊肿逐渐增大可出现压迫症状。\n【建议】\n【建议】\n建议专科治疗。\n中性粒细胞百分数（\n降低\n中性粒细胞百分数（NEUT% ） ） 降低\n结果: 46.5 %\n范围:50.00-70.00 %\n【医学解释】\n【医学解释】\n白细胞分类计数是指计算各类白细胞（中性粒细胞、淋巴细胞、嗜酸性粒细胞、嗜碱性粒细胞和单核细胞）\n的百分数和绝对值，通过对染色血涂片，进行细胞分类，求得各类白细胞的百分数，对各种疾病的诊断有着\n重要的参考价值。\n【常见原因及后果】\n【常见原因及后果】\n粒细胞减少： 1.感染性疾病：革兰阴性杆菌感染，如伤寒、副伤寒，白细胞总数与中性粒细胞均减少；某些\n病毒感染，如流感、水痘、风疹，白细胞亦常减低；某些原虫感染，如疟疾、黑热病等 ，白细胞可减少。 2.\n血液系统疾病：如再障、巨幼细胞贫血、粒细胞减少症等。 3.慢性理化损伤：长期接触放射线；应用某些化\n学药物，如氯霉素、抗肿瘤药；某些化学物质，如苯、铅汞等，均可引起白细胞及中性粒细胞减少。 4.自身\n免疫性疾病：如系统性红斑狼疮（SLE）等，产生自身抗体导致白细胞减少。 5.单核－巨噬细胞系统功能亢\n进，如脾功能亢进、淋巴瘤、类脂质沉积病等。\n【建议】\n【建议】\n粒细胞异常减少，建议及时复查，如果仍然异常，请尽早去医院，查明原因。\n淋巴细胞百分数（LYM% ） ） 增高\n淋巴细胞百分数（\n增高\n结果: 44.4 %\n范围:20.00-40.00 %\n【医学解释】\n【医学解释】\n白细胞分类计数是指计算各类白细胞（中性粒细胞、淋巴细胞、嗜酸性粒细胞、嗜碱性粒细胞和单核细胞）\n的百分数和绝对值，通过对染色血涂片，进行细胞分类，求得各类白细胞的百分数，对各种疾病的诊断有着\n重要的参考价值。\n【常见原因及后果】\n【常见原因及后果】\n淋巴细胞增高： ⑴ 病毒感染性疾病。 ⑵ 急、慢性淋巴细胞性白血病，淋巴瘤。 ⑶ 慢性炎症，急性传染病的\n恢复期。 ⑷ 组织移植后的排斥反应。\n【建议】\n【建议】\n淋巴细胞异常，建议复查，如果仍然异常，请尽早去医院，查明原因。\n血小板压积（PCT） ） 增高\n血小板压积（\n增高\n结果: 0.338 %\n【医学解释】\n【医学解释】\n范围:0.10-0.28 %\n血小板压积(PCT)是指抗凝全血经离心沉淀后，测得下沉的血小板在全血中所占容积的百分比值。\n【常见原因及后果】\n【常见原因及后果】\n在健康人群中该指标意义不大。\n【建议】\n【建议】\n血小板压积异常，建议复查，如果仍然异常，请去医院，查明原因。\n血小板计数（PLT） ） 增高\n血小板计数（\n增高\n结果: 357 10^9/L\n范围:100-300 10^9/L\n【医学解释】\n【医学解释】\n血小板由骨髓中的成熟巨核细胞产生，直径2～4μm，寿命10天左右。血小板的数量和质量与止血和凝血功能\n密切相关。\n【常见原因及后果】\n【常见原因及后果】\n血小板增多见于：①原发性增多，如原发性血小板增多症，真性红细胞增多症等；②反应性增多，如急性感\n染，急性大出血，急性溶血等。血小板＞600×10^9/L可发生血栓性疾病。\n【建议】\n【建议】\n血小板计数异常，建议及时复查，如果仍然异常，请尽早去医院，查明原因。\n【一般检查】\n【一般检查】 检查者\n检查者:吴梦怡\n吴梦怡\nB201600279\n检查项目名称 结果 单位 正常范围值\n身高 166.0 Cm\n体重 61.1 kg\n体重指数(18.5-23.9) 22.2\n理想体重(kg) 59.4\n收缩压 115 mmHg\n舒张压 68 mmHg\n脉搏（次/分） 77\n体重指数:22.2\n小结\n血压:115/68mmHg\n脉搏:77 次/分\n【内科】 检查者\n【内科】\n徐静\n检查者:徐静\n检查项目名称 结果 单位 正常范围值\n病史 无\n心率 78 次/分\n呼吸 18 次/分\n心律 整齐\n心音 未见异常\n心脏杂音 未见异常\n心脏其他 未见异常\n肺罗音 未见异常\n呼吸音 未见异常\n腹壁 未见异常\n肝大小 未见异常\n肝脏质地 未见异常\n肝脏压痛 未见异常\n脾大小 未见异常\n脾脏质地 未见异常\n脾脏压痛 未见异常\n其他 未见异常\n小结 内科未发现明显异常\n【外科】 检查者\n【外科】\n检查者:杨建华\n杨建华\n检查项目名称 结果 单位 正常范围值\n皮肤颜色 未见异常\n皮疹 无\n皮下肿块 无\n水肿 无\n蜘蛛痣 无\n疤痕部位 无\n溃疡部位 无\n糜烂部位 无\n淋巴结 未见异常\n甲状腺 未见异常\n乳房 未见异常\n四肢关节 未见异常，活动自如\n脊柱 未见异常，活动自如\n疝 无\n包皮 弃查\n阴茎 弃查\n睾丸 弃查\n前列腺 未见异常\n其他检查 无\n小结 外科未发现明显异常\n【静态心电图】\n【静态心电图】 检查者\n唐永鹏\n检查者:唐永鹏\n检查项目名称 结果 单位 正常范围值\n小结 窦性心动过缓(54次/分)\n【肝胆脾胰肾彩超】 检查者\n【肝胆脾胰肾彩超】\n检查者:郭娟\n郭娟 审核者\n孙立\n审核者: 孙立\nB201600279\n检查项目名称 结果 单位 正常范围值\n肝 肝脏大小、形态正常，包膜光整，肝内血管走行较清\n晰，光点分布尚均匀，其内未见明显异常光团。\n胆 胆囊大小、形态正常，囊壁光整，囊腔内透声好，胆\n总管无扩张。\n胰 胰腺大小、形态正常，边缘规整，内部回声均匀，胰\n管未见扩张。\n脾 脾脏大小、形态正常，包膜光整，内光点均匀。\n左肾 左肾大小、形态正常，包膜光滑，肾实质回声均匀，\n集合系统未见明显分离。\n右肾 右肾大小、形态正常，包膜光滑，肾实质回声均匀，\n集合系统未见明显分离。\n小结 肝、胆、胰、脾、左肾、右肾未发现明显异常\n【甲状腺彩超】 检查者\n【甲状腺彩超】\n检查者:郭娟\n郭娟 审核者\n孙立\n审核者: 孙立\n检查项目名称 结果 单位 正常范围值\n甲状腺形态大小正常，甲状腺双叶内均可见多个类圆形\n描述\n无回声区,最大位于右叶，大小约2mm×3mm，后方回\n声增强，内部未见血流。\n小结 甲状腺双叶囊肿（多发）\n【前列腺彩超】 检查者\n【前列腺彩超】\n检查者:郭娟\n郭娟 审核者\n孙立\n审核者: 孙立\n检查项目名称 结果 单位 正常范围值\n前列腺 前列腺大小、形态正常，包膜光滑完整，两侧对\n称，内部回声均匀。\n小结 前列腺未发现明显异常\n【胸部CT】 】 检查者\n【胸部\n检查者:顾松鸿\n顾松鸿 审核者\n徐建良\n审核者: 徐建良\n检查项目名称 结果 单位 正常范围值\n两侧胸廓对称。肺窗示两肺纹理清晰，走行自然，未见\n明显异常密度影。两侧肺门不大。纵隔窗示心影及大血\n描述\n管形态正常，纵隔内未见肿块及明显肿大淋巴结。无胸\n腔积液及胸膜增厚。\n小结 胸部CT平扫未见明显异常\n【癌胚抗原检测定量】\n【癌胚抗原检测定量】 检验者\n检验者:王娜娜\n王娜娜 审核者\n王丽华\n审核者:王丽华\n检查项目名称 结果 单位 正常范围值\n癌胚抗原测定定量(CEA) 0.896 ng/mL 0-5\n【甲胎蛋白检测定量】\n【甲胎蛋白检测定量】 检验者\n检验者:王娜娜\n王娜娜 审核者\n王丽华\n审核者:王丽华\n检查项目名称 结果 单位 正常范围值\n甲胎蛋白测定定量 (AFP) 2.44 ng/mL 0-10\n【空腹血糖】 检验者\n【空腹血糖】\n检验者:董军\n董军 审核者\n审核者:王燕\n王燕\n检查项目名称 结果 单位 正常范围值\n空腹血糖(GLU) 4.76 mmol/L 3.9-6.1\n【尿常规2】 】 检验者\n【尿常规\n检验者:石桂宁\n石桂宁 审核者\n审核者:王燕\n王燕\n检查项目名称 结果 单位 正常范围值\n尿维生素C(VC) 阴性\n尿白细胞酯酶(LEU) 阴性 阴性\n尿酮体(KET) 阴性 阴性\n尿亚硝酸盐(NIT) 阴性 阴性\n尿胆原